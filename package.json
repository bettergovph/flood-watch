  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "build:cloudflare": "npm run build && rm -rf dist/datasets",
    "lint": "eslint .",
    "preview": "vite preview --host 0.0.0.0",
